<?xml version="1.0" encoding="utf-8"?>
<PackageConfiguration xmlns="http://www.siemens.com/automation/Openness/AddIn/Publisher/V21">
  <Author>TIA Portal Code Agent</Author>
  <AddInVersion>V21</AddInVersion>
  <Description>AI-powered engineering assistant for TIA Portal V21</Description>
  <DisplayInMultiuser />

  <Product>
    <Name>TIA Portal Code Agent</Name>
    <Id>tia_portal_code_agent</Id>
    <Version>0.1.0</Version>
  </Product>

  <FeatureAssembly>
    <AssemblyInfo>
      <Assembly>TiaAgent.AddIn.dll</Assembly>
    </AssemblyInfo>
  </FeatureAssembly>

  <AdditionalAssemblies>
    <AssemblyInfo>
      <Assembly>TiaAgent.Contracts.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>TiaAgent.Application.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>TiaAgent.OpenCode.dll</Assembly>
    </AssemblyInfo>
    <!-- Transitive NuGet dependencies -->
    <AssemblyInfo>
      <Assembly>Microsoft.Extensions.Logging.Abstractions.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>Microsoft.Extensions.DependencyInjection.Abstractions.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>Microsoft.Bcl.AsyncInterfaces.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>System.Buffers.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>System.Memory.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>System.Numerics.Vectors.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>System.Runtime.CompilerServices.Unsafe.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>System.Threading.Tasks.Extensions.dll</Assembly>
    </AssemblyInfo>
  </AdditionalAssemblies>

  <RequiredPermissions>
    <TIAPermissions>
      <TIA.ReadWrite/>
    </TIAPermissions>
    <UnrestrictedPermissions>
      <System.UnrestrictedAccess>
        <JustificationComment>Needed for file I/O, logging, and network access for MCP communication</JustificationComment>
      </System.UnrestrictedAccess>
    </UnrestrictedPermissions>
  </RequiredPermissions>
</PackageConfiguration>
