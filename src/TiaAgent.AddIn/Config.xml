<?xml version="1.0" encoding="utf-8"?>
<PackageConfiguration xmlns="http://www.siemens.com/automation/Openness/AddIn/Publisher/V21">
  <Author>allan@industrix.it</Author>
  <AddInVersion>V21</AddInVersion>
  <Description>AI-powered engineering assistant for TIA Portal V21</Description>
  <DisplayInMultiuser />

  <Product>
    <Name>TIA Portal Code Agent</Name>
    <Id>tia_portal_code_agent</Id>
    <Version>__PRODUCT_VERSION__</Version>
  </Product>

  <FeatureAssembly>
    <AssemblyInfo>
      <Assembly>TiaAgent.AddIn.dll</Assembly>
    </AssemblyInfo>
  </FeatureAssembly>

  <AdditionalAssemblies>
    <AssemblyInfo>
      <Assembly>TiaAgent.Contracts.dll</Assembly>
    </AssemblyInfo>
    <AssemblyInfo>
      <Assembly>Markdig.dll</Assembly>
    </AssemblyInfo>
  </AdditionalAssemblies>

  <RequiredPermissions>
    <TIAPermissions>
      <TIA.ReadWrite/>
    </TIAPermissions>

    <SecurityPermissions>
      <!-- Required for WPF Window/UserControl creation and display.
           Without this, TIA Portal's sandbox blocks all WPF UI elements
           (Window, UserControl) but still allows MessageBox (Win32 dialog).
           Code path: AssistantPanelFactory.ShowWpfWindow() -->
      <System.Security.Permissions.UIPermission />

      <!-- Required for file-based logging to %LOCALAPPDATA%\TiaAgent\logs\.
           Without this, AddInLogger must be a no-op and all diagnostics are lost.
           Code path: AddInLogger.Log(), Directory.CreateDirectory, File.AppendAllText -->
      <System.Security.Permissions.FileIOPermission />

      <!-- Required for Environment.GetFolderPath() and environment variable access.
           Without this, the static field initializer LogDir throws SecurityException
           on first class access, causing TypeInitializationException that prevents
           Add-In loading before any code in Startup() executes.
           Code path: AddInLogger.GetLogDir(), Environment.OSVersion, Environment.Version -->
      <System.Security.Permissions.EnvironmentPermission />

      <!-- Required for WPF Window constructor (System.Windows.Window..ctor).
           The Window constructor calls SecurityPermission.Demand(UnmanagedCode)
           internally. Without this, new Window() throws SecurityException even
           when UIPermission is granted.
           Note: MessageBox (Win32 User32.dll) works without this because it does
           not go through WPF's CAS demand chain.
           Code path: new Window() in AssistantPanelFactory.TryShowWpfWindow() -->
      <System.Security.Permissions.SecurityPermission.UnmanagedCode />

      <!-- Required for HttpClient HTTP requests to the Bridge process.
           Without this, HttpClient.GetAsync/PostAsync throw SecurityException
           with "Request for the permission of type System.Net.WebPermission".
           Code path: AgentBridgeClient.StartTaskAsync(), GetTaskAsync(),
           CheckHealthAsync() — all HTTP calls to the local Bridge. -->
      <System.Net.WebPermission />
    </SecurityPermissions>
  </RequiredPermissions>
</PackageConfiguration>
