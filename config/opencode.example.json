{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 43120
  },
  "mcp": {
    "tia-portal": {
      "type": "local",
      "command": ["tia-mcp"],
      "enabled": true
    }
  },
  "agents": {
    "default": "tia-explain",
    "available": [
      "tia-explain",
      "tia-review",
      "tia-change"
    ]
  },
  "model": {
    "provider": "openai",
    "model": "gpt-4o"
  }
}
