## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
/[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Bb]uild/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
*.snupkg
**/packages/
*.nuget.props
*.nuget.targets

# dotenv environment variables file
.env
.env.*

# Local configuration (generated from examples)
config/appsettings.json
config/opencode.json
config/bridge.json
config/settings.json

# Logs
*.log
logs/
mcp-error.log
mcp-output.log

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
launchSettings.json

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# Publish output
publish/
PublishOutput/

# CodeCoverage
CodeCoverage/
coverage/
*.coverage
*.coveragexml

# Temporary files
~$*
*~
*.tmp
*.bak
*.swp
*~
.nfs*

# Local tools
.tools/
.dotnet/
.nuget/

# AI tools
.mimocode/
.claude/
.opencode/

# Environment
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# Others
~$*
