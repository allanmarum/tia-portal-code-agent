# Auto detect text files and perform LF normalization
* text=auto eol=crlf

# Explicitly declare text files
*.cs text eol=crlf
*.csproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.md text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.txt text eol=crlf

# Declare binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.nupkg binary
*.addin binary
